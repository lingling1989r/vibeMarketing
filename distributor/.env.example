# PodAha Distributor — Environment Variables
# Copy this to .env and fill in your credentials
# Run: cp .env.example .env

# ─── International ───────────────────────────────────────────────────────────

# Twitter/X (OAuth 1.0a — for posting tweets)
# Create app at https://developer.twitter.com/
# Also install: npm install oauth-1.0a
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Dev.to (simplest — just an API key)
# Get from https://dev.to/settings/extensions → DEV Community API Keys
DEVTO_API_KEY=

# Medium (Integration Token)
# Get from https://medium.com/me/settings → Security → Integration tokens
MEDIUM_TOKEN=

# Reddit (Script app)
# Create app at https://www.reddit.com/prefs/apps (choose "script")
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Hashnode (Personal Access Token)
# Get from https://hashnode.com/settings/developer
HASHNODE_TOKEN=
HASHNODE_PUBLICATION_ID=

# ─── Chinese Platforms ────────────────────────────────────────────────────────

# 百家号 (Baijiahao / Baidu)
# 申请开发者：https://baijiahao.baidu.com/builder/author/openauth/
BAIJIAHAO_APP_ID=
BAIJIAHAO_APP_TOKEN=

# 头条号 (Toutiao / ByteDance)
# 申请开发者：https://open.mp.toutiao.com
TOUTIAO_APP_ID=
TOUTIAO_APP_SECRET=
TOUTIAO_ACCESS_TOKEN=

# CSDN
# 申请开发者 API：https://open.csdn.net
CSDN_CLIENT_ID=
CSDN_ACCESS_TOKEN=

# 搜狐号 — 目前通过 MultiPost 浏览器插件分发
# 无官方开放 API，建议安装 MultiPost: https://multipost.app

# 简书 — 无官方 API，通过 MultiPost 分发
# 或使用 Cookie 自动化（不推荐）

# 知乎专栏 — 通过 MultiPost 或手动发布
# 官方 API 仅对部分合作伙伴开放

# ─── Content Generation ───────────────────────────────────────────────────────

# Anthropic API (for content/generator.js)
# Or use OpenClaw proxy
ANTHROPIC_API_KEY=
# If using OpenClaw: set base URL
# ANTHROPIC_BASE_URL=https://your-openclaw-endpoint
